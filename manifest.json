{
  "manifest_version": 3,
  "name": "InstagramPro - Advanced Automation",
  "version": "2.0.0",
  "description": "Mode-based Instagram automation: Posts, Reels, Stories, Search & Follow with CSV upload",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content-scripts/instagram-improved.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["content-scripts/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
